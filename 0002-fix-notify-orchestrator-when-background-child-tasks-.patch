+  test('session.created during fallback drops phantom job and preserves completion path (peek not take)', async () => {
+    const board = new BackgroundJobBoard();
+
+    // Pre-register child-1 as a phantom running job — simulates the
+    // preserved entry from session.deleted when isFallbackInProgress was
+    // true.
+    board.registerLaunch({
+      taskID: 'child-1',
+      parentSessionID: 'parent-1',
+      agent: 'explorer',
+      description: 'phantom child from fallback abort',
+    });
+    expect(board.get('child-1')).toMatchObject({ state: 'running' });
+
+    const { hook } = createHook({
+      backgroundJobBoard: board,
+      isFallbackInProgress: (id) => id === 'parent-1',
+    });
+
+    // Seed a pending call for child-2's launch
+    await hook['tool.execute.before'](
+      { tool: 'task', sessionID: 'parent-1', callID: 'call-1' },
+      {
+        args: {
+          subagent_type: 'explorer',
+          description: 'retried child task',
+        },
+      },
+    );
+
+    // Dispatch session.created for child-2 during fallback
+    await hook.event({
+      event: {
+        type: 'session.created',
+        properties: { info: { id: 'child-2', parentID: 'parent-1' } },
+      },
+    });
+
+    // Phantom child-1 must be dropped by the net
+    expect(board.get('child-1')).toBeUndefined();
+
+    // child-2 should be registered (running) via peek
+    const job = board.get('child-2');
+    expect(job).toBeDefined();
+    expect(job).toMatchObject({
+      taskID: 'child-2',
+      parentSessionID: 'parent-1',
+      state: 'running',
+      agent: 'explorer',
+    });
+
+    // The pending call was peeked, not taken — so tool.execute.after
+    // still receives it and can register completion (no swallow).
+    await hook['tool.execute.after'](
+      { tool: 'task', sessionID: 'parent-1', callID: 'call-1' },
+      { output: ['task_id: child-2', 'state: completed'].join('\n') },
+    );
+
+    // child-2 must be completed (not swallowed)
+    const completed = board.get('child-2');
+    expect(completed).toBeDefined();
+    expect(completed).toMatchObject({ state: 'completed' });
+
+    // child-1 still gone
+    expect(board.get('child-1')).toBeUndefined();
+  });
+
