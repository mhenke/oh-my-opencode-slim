+  test('does NOT drop job on session.deleted when fallback was recent (grace window)', async () => {
+    const coordinator = new SessionLifecycle(() => {});
+    const board = new BackgroundJobBoard();
+    board.registerLaunch({
+      taskID: 'child-1',
+      parentSessionID: 'parent-1',
+      agent: 'oracle',
+      description: 'architecture review',
+    });
+    expect(board.get('child-1')).toMatchObject({ state: 'running' });
+
+    createHook({
+      backgroundJobBoard: board,
+      coordinator,
+      // Strict in-flight guard already cleared (finally ran), but the grace
+      // window is still active — the late abort-induced session.deleted must
