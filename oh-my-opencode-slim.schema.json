        },
        "binaryPath": {
          "description": "Path to a custom companion binary to launch.",
          "type": "string",
          "minLength": 1
        },
        "position": {
          "type": "string",
          "enum": [
            "bottom-right",
            "bottom-left",
            "top-right",
            "top-left"
          ]
        },
        "size": {
          "type": "string",
          "enum": [
