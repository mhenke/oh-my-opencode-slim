          "type": "string",
          "enum": [
            "classic",
            "smooth"
          ]
        },
        "speed": {
          "description": "Companion animation playback speed multiplier. Defaults to 1.",
          "type": "number",
          "minimum": 0.25,
          "maximum": 4
        },
        "debug": {
          "description": "Enable verbose native companion debug logs.",
          "type": "boolean"
        }
      }
    },
    "acpAgents": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
